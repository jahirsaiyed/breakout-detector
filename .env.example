# ---- Backend (Render) environment ----
# Supabase Postgres — use the SESSION POOLER connection string (IPv4; Render cannot reach
# Supabase's IPv6-only direct host). Find it in Supabase → Project → Connect → Session pooler.
SPRING_DATASOURCE_URL=jdbc:postgresql://aws-0-<region>.pooler.supabase.com:5432/postgres?sslmode=require
SPRING_DATASOURCE_USERNAME=postgres.<your-project-ref>
SPRING_DATASOURCE_PASSWORD=<your-supabase-db-password>

# Lock CORS to your deployed frontend (comma-separated for multiple)
APP_CORS_ALLOWED_ORIGINS=https://your-app.vercel.app

H2_CONSOLE_ENABLED=false
APP_SCAN_RUN_ON_STARTUP=false

# ---- Frontend (Vercel) environment ----
# Public base URL of the Render backend API (note the /breakout-detector context path)
NEXT_PUBLIC_API_BASE=https://breakout-detector-api.onrender.com/breakout-detector
